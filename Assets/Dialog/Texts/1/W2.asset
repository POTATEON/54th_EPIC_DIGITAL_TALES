  text: "\u0421\u0442\u0435\u043F\u0435\u043D\u044C \u0438 \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0442 \u043E\u0434\u043D\u043E
    \u0438 \u0442\u043E \u0436\u0435, \u043D\u043E \u0441 \u0440\u0430\u0437\u043D\u044B\u0445
    \u0441\u0442\u043E\u0440\u043E\u043D.\r\n\r\n\u0421\u0442\u0435\u043F\u0435\u043D\u044C:
    2\xB3 = 8\r\n\u041B\u043E\u0433\u0430\u0440\u0438\u0444\u043C: log\u20828 = 3\r\n\r\n\u0415\u0441\u043B\u0438
    \u0437\u043D\u0430\u0435\u0448\u044C \u043E\u0434\u043D\u043E, \u0432\u0441\u0435\u0433\u0434\u0430
    \u043D\u0430\u0439\u0434\u0451\u0448\u044C \u0434\u0440\u0443\u0433\u043E\u0435."
