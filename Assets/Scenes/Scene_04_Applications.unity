    log\u20828 = ?\r\n\r\n2 \u0432 \u043A\u0430\u043A\u043E\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438
    \u0434\u0430\u0451\u0442 8? 2\xB3 = 8, \n\u0437\u043D\u0430\u0447\u0438\u0442
