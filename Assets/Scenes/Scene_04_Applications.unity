  m_text: "\u0427\u0442\u043E \u0442\u0430\u043A\u043E\u0435 \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\n\r\n\u041B\u043E\u0433\u0430\u0440\u0438\u0444\u043C
    \u043E\u0442\u0432\u0435\u0447\u0430\u0435\u0442 \u043D\u0430 \u0432\u043E\u043F\u0440\u043E\u0441:
    \u0432 \u043A\u0430\u043A\u0443\u044E \u0441\u0442\u0435\u043F\u0435\u043D\u044C
    \u0432\u043E\u0437\u0432\u0435\u0441\u0442\u0438 \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u0435,
