  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::WorldTip
  message: "\u0427\u0442\u043E \u0442\u0430\u043A\u043E\u0435 \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\n\n\u041B\u043E\u0433\u0430\u0440\u0438\u0444\u043C
    \u043E\u0442\u0432\u0435\u0447\u0430\u0435\u0442 \u043D\u0430 \u0432\u043E\u043F\u0440\u043E\u0441:
    \u0432 \u043A\u0430\u043A\u0443\u044E \u0441\u0442\u0435\u043F\u0435\u043D\u044C
    \u0432\u043E\u0437\u0432\u0435\u0441\u0442\u0438 \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u0435,
    \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
    \u0430\u0440\u0433\u0443\u043C\u0435\u043D\u0442?\n\n\u041F\u0440\u0438\u043C\u0435\u0440:
    log\u20828 = ?\n\n2 \u0432 \u043A\u0430\u043A\u043E\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438
    \u0434\u0430\u0451\u0442 8? 2\xB3 = 8, \n\u0437\u043D\u0430\u0447\u0438\u0442
    log\u20828 = 3.\n\n\u041B\u043E\u0433\u0430\u0440\u0438\u0444\u043C \u2014 \u044D\u0442\u043E
    \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C \u0441\u0442\u0435\u043F\u0435\u043D\u0438."
  offset: {x: 0, y: 3.76, z: 0}
  hideMode: 1
  showDuration: 1
  showOnce: 0
  fadeDuration: 0.25
  fontSize: 2
  textColor: {r: 1, g: 1, b: 1, a: 1}
