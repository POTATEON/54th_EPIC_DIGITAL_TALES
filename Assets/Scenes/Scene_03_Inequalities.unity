  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 011772197e177a24aa8cbf8880797406, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::WorldTip
  message: "\u041D\u0435\u0440\u0430\u0432\u0435\u043D\u0441\u0442\u0432\u043E \u043F\u043E\u0445\u043E\u0436\u0435
    \u043D\u0430 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435, \u043D\u043E
    \u0432\u043C\u0435\u0441\u0442\u043E \u0437\u043D\u0430\u043A\u0430 \xAB=\xBB
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0442\u0441\u044F \u0437\u043D\u0430\u043A\u0438
    \xAB>\xBB, \xAB<\xBB, \xAB\u2265\xBB, \xAB\u2264\xBB.\r\n\r\n\u0412\u0430\u0436\u043D\u043E\u0435
    \u043F\u0440\u0430\u0432\u0438\u043B\u043E:\r\n\r\n\u0415\u0441\u043B\u0438 \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u0435
    \u0431\u043E\u043B\u044C\u0448\u0435 1 \u2014 \u0437\u043D\u0430\u043A \u0441\u043E\u0445\u0440\u0430\u043D\u044F\u0435\u0442\u0441\u044F.\r\n\r\n\u0415\u0441\u043B\u0438
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u0435 \u043E\u0442 0 \u0434\u043E
    1 \u2014 \u0437\u043D\u0430\u043A \u043C\u0435\u043D\u044F\u0435\u0442\u0441\u044F
    \u043D\u0430 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u043F\u043E\u043B\u043E\u0436\u043D\u044B\u0439.\r\n\r\n\u0422\u0430\u043A\u0436\u0435
    \u043D\u0443\u0436\u043D\u043E \u043F\u043E\u043C\u043D\u0438\u0442\u044C \u043F\u0440\u043E
    \u043E\u0431\u043B\u0430\u0441\u0442\u044C \u0434\u043E\u043F\u0443\u0441\u0442\u0438\u043C\u044B\u0445
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0439: \u0430\u0440\u0433\u0443\u043C\u0435\u043D\u0442
    \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u0430 \u0432\u0441\u0435\u0433\u0434\u0430
    \u0431\u043E\u043B\u044C\u0448\u0435 \u043D\u0443\u043B\u044F.\r\n\r\n\u0412
    \u044D\u0442\u043E\u0439 \u0442\u0435\u043C\u0435 \u0442\u044B \u043D\u0430\u0443\u0447\u0438\u0448\u044C\u0441\u044F
    \u0440\u0435\u0448\u0430\u0442\u044C \u043D\u0435\u0440\u0430\u0432\u0435\u043D\u0441\u0442\u0432\u0430
    \u0438 \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u0442\u044C
    \u0437\u043D\u0430\u043A."
  offset: {x: 0, y: 3.76, z: 0}
  hideMode: 1
  showDuration: 1
  showOnce: 0
  fadeDuration: 0.25
  fontSize: 2
  textColor: {r: 1, g: 1, b: 1, a: 1}
