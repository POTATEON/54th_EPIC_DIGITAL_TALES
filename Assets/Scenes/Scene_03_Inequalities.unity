    \u0432\u043E\u0437\u0432\u0435\u0441\u0442\u0438 \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u0435,
    \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
    \u0430\u0440\u0433\u0443\u043C\u0435\u043D\u0442?\r\n\r\n\u041F\u0440\u0438\u043C\u0435\u0440:
    log\u20828 = ?\r\n\r\n2 \u0432 \u043A\u0430\u043A\u043E\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438
    \u0434\u0430\u0451\u0442 8? 2\xB3 = 8, \n\u0437\u043D\u0430\u0447\u0438\u0442
    log\u20828 = 3.\r\n\r\n\u041B\u043E\u0433\u0430\u0440\u0438\u0444\u043C \u2014
    \u044D\u0442\u043E \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C
    \u0441\u0442\u0435\u043F\u0435\u043D\u0438."
