--- !u!114 &1378535007
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1378535004}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 011772197e177a24aa8cbf8880797406, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::WorldTip
  message: " \u0412\u0440\u0430\u0433\r\n\r\n\u041D\u0430\u0434 \u0432\u0440\u0430\u0433\u043E\u043C
    \u0432\u0438\u0441\u0438\u0442 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0432\u044B\u0440\u0430\u0436\u0435\u043D\u0438\u0435. \u041F\u043E\u043A\u0430
    \u043E\u043D\u043E \u043D\u0435 \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u0442\u0441\u044F
    \u0432 \u0447\u0438\u0441\u043B\u043E, \u0432\u0440\u0430\u0433 \u043D\u0435\u0443\u044F\u0437\u0432\u0438\u043C
    \u0438 \u0442\u044B \u043D\u0435 \u043C\u043E\u0436\u0435\u0448\u044C \u043A
    \u043D\u0435\u043C\u0443 \u043F\u043E\u0434\u043E\u0439\u0442\u0438. \u041F\u0440\u0438\u043C\u0435\u043D\u044F\u0439
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438 \u0441 \u043F\u0430\u043D\u0435\u043B\u0438
    \u0432\u043D\u0438\u0437\u0443, \u0447\u0442\u043E\u0431\u044B \u0443\u043F\u0440\u043E\u0449\u0430\u0442\u044C
    \u0432\u044B\u0440\u0430\u0436\u0435\u043D\u0438\u0435. \u041A\u043E\u0433\u0434\u0430
    \u0432\u044B\u0440\u0430\u0436\u0435\u043D\u0438\u0435 \u0441\u0442\u0430\u043D\u0435\u0442
